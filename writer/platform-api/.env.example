# ============================================================
# Platform API — Environment Variables
# ============================================================
# Copy this file to .env (DO NOT COMMIT .env) and fill in values.
# Set these same vars in Railway under Settings → Variables.

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# ------------------------------------------------------------
# Pipeline API (private Railway network address)
# ------------------------------------------------------------
PIPELINE_API_URL=http://pipeline-api.railway.internal

# ------------------------------------------------------------
# External APIs (used by platform-api for website scraping)
# ------------------------------------------------------------
SCRAPEOWL_API_KEY=your_scrapeowl_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ------------------------------------------------------------
# Application config
# ------------------------------------------------------------
MAX_CONCURRENT_RUNS=5
JOB_WORKER_POLL_INTERVAL_SECONDS=10
LOG_LEVEL=INFO

# ------------------------------------------------------------
# CORS — Lovable frontend domain(s); comma-separated
# ------------------------------------------------------------
ALLOWED_ORIGINS=https://your-lovable-app.lovable.app

# Outscraper API key — Google Business Profile (GBP) auto-fetch
OUTSCRAPER_API_KEY=

# DataForSEO — GBP review enrichment (top reviews on a business profile)
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your_api_password

# ─────────────────────────────────────────────────────────────────────────────
# Topic Fanout Tool (vendored fanout/ sub-package, mounted at /fanout)
# Supabase + DataForSEO above are SHARED (same project/creds). Set the rest on
# the PLATFORM service. All keys default empty → features stay dormant until set.
# ─────────────────────────────────────────────────────────────────────────────
# Required for the Fanout pipeline:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# SIE module (page scraping + entity NER):
SCRAPEOWL_API_KEY=
TEXTRAZOR_API_KEY=
# Embeddings provider (default openai; gemini is dormant/optional):
# EMBEDDING_PROVIDER=openai
# GEMINI_API_KEY=
# Optional publish destinations (Articles tab; dormant until set):
# GITHUB_PUBLISH_TOKEN=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
# CORS is handled by the host app (ALLOWED_ORIGINS); CORS_ALLOW_ORIGINS unused when mounted.
