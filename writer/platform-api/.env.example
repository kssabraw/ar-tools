# ============================================================
# Platform API — Environment Variables
# ============================================================
# Copy this file to .env (DO NOT COMMIT .env) and fill in values.
# Set these same vars in Railway under Settings → Variables.

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET

# ------------------------------------------------------------
# Pipeline API (private Railway network address)
# ------------------------------------------------------------
PIPELINE_API_URL=http://pipeline-api.railway.internal

# ------------------------------------------------------------
# External APIs (used by platform-api for website scraping)
# ------------------------------------------------------------
SCRAPEOWL_API_KEY=your_scrapeowl_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ------------------------------------------------------------
# Application config
# ------------------------------------------------------------
MAX_CONCURRENT_RUNS=5
JOB_WORKER_POLL_INTERVAL_SECONDS=10
LOG_LEVEL=INFO

# ------------------------------------------------------------
# CORS — Lovable frontend domain(s); comma-separated
# ------------------------------------------------------------
ALLOWED_ORIGINS=https://your-lovable-app.lovable.app
