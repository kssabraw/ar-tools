# ============================================================
# Pipeline API — Environment Variables
# ============================================================
# Copy this file to .env (DO NOT COMMIT .env) and fill in values.
# Set these same vars in Railway under Settings → Variables.

# ------------------------------------------------------------
# Supabase
# ------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------------------------------------------------------------
# DataForSEO (Brief Generator + SIE modules)
# ------------------------------------------------------------
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your_api_password

# ------------------------------------------------------------
# OpenAI
#   - SIE embeddings: text-embedding-3-small
#   - Brief Generator v2.0 embeddings: text-embedding-3-large
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# Anthropic (content generation — claude-sonnet-4-6)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# ScrapeOwl (page scraping for SIE)
# ------------------------------------------------------------
SCRAPEOWL_API_KEY=your_scrapeowl_api_key

# ------------------------------------------------------------
# Google Cloud Natural Language API (SIE entity extraction)
# Simple API key from Google Cloud Console — no service account needed.
# ------------------------------------------------------------
GOOGLE_NLP_API_KEY=AIzaSy...

# ------------------------------------------------------------
# Application config
# ------------------------------------------------------------
SIE_CACHE_TTL_DAYS=7
SIE_MIN_PAGES=5
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Brief Generator v2.0 — threshold tuning (PRD §12.6)
# ------------------------------------------------------------
# All thresholds are configurable, never hardcoded. Defaults match the
# PRD's recommended starting values; expect first-week tuning, especially
# on the restatement ceiling (most consequential, most sensitive).
BRIEF_RELEVANCE_FLOOR=0.55
BRIEF_RESTATEMENT_CEILING=0.78
BRIEF_INTER_HEADING_THRESHOLD=0.75
BRIEF_EDGE_THRESHOLD=0.65
BRIEF_MMR_LAMBDA=0.7
BRIEF_LOUVAIN_RESOLUTION=1.0
BRIEF_LOUVAIN_SEED=42

# Tuning mode: when true the pipeline emits per-candidate scores in the
# response metadata (even for discards). Useful during threshold tuning.
BRIEF_TUNING_MODE=false

# 7-day brief cache (keyword + location_code shared across clients).
BRIEF_CACHE_TTL_DAYS=7
